# Zotero settings
ZOTERO_API_URL=http://127.0.0.1:23119
ZOTERO_API_KEY=
ZOTERO_LIBRARY_ID=

# DOI + Zotero Connector import settings
DOI_BIBTEX_BASE_URL=https://doi.org/
DOI_BIBTEX_TIMEOUT_SECONDS=10

# Zotero Connector import endpoint (served by local Zotero Connector)
ZOTERO_CONNECTOR_IMPORT_PATH=/connector/import
ZOTERO_CONNECTOR_TIMEOUT_SECONDS=15
ZOTERO_DEFAULT_IMPORT_COLLECTION_KEY=

# Ollama settings
OLLAMA_BASE_URL=http://localhost:11434
EMBEDDING_MODEL=qwen3-embedding:4b
RERANKER_MODEL=dengcao/Qwen3-Reranker-0.6B:Q8_0

# Embedding dimensions (0 = auto-detect from model)
EMBEDDING_DIMENSIONS=1024

# Search parameters
DEFAULT_TOP_X=10
DEFAULT_TOP_Y=5

# Storage paths
VECTOR_STORE_DIR=./data/vector_store
PDF_CACHE_PATH=./data/pdfs

# Embedding options
AUTO_EMBED_SENTENCES=false

# Threading for embedding (0 = auto-detect based on CPU cores)
MAX_EMBEDDING_WORKERS=9

# Batch embedding settings
BATCH_EMBEDDING_SIZE=128

# PDF processing options
PAGE_SPLITS=4